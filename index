// Load from localStorage or use defaults
function loadTasks() {
  try {
    const stored = localStorage.getItem(STORAGE_KEY);
    if (stored) return JSON.parse(stored);
  } catch(e) {}
  return JSON.parse(JSON.stringify(DEFAULT_TASKS));
}

function saveTasks() {
  try {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(tasks));
    const now = new Date();
    document.getElementById('last-save').textContent = 
      `Rob Hichens · Last saved ${now.toLocaleDateString()} ${now.toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'})}`;
  } catch(e) {}
}

let tasks = loadTasks();
let nextId = Math.max(...tasks.map(t => t.id), 0) + 1;
const expandedIds = {};

function siteLabel(s) { return SITES[s] || s; }
function siteBadge(s) { return `<span class="badge b-${s}">${siteLabel(s)}</span>`; }
function statusBadge(s) {
  const map = { critical: ['b-crit','Critical'], inprogress: ['b-prog','In progress'], monitoring: ['b-mon','Monitoring'], done: ['b-done','Done'] };
  const [cls, lbl] = map[s] || ['b-all', s];
  return `<span class="badge ${cls}">${lbl}</span>`;
}
function priorityFlag(p) {
  if (!p) return '';
  return `<span class="flag flag-${p}">P${p}</span>`;
}

function updateStats() {
  const c = { critical: 0, inprogress: 0, monitoring: 0, done: 0 };
  tasks.forEach(t => c[t.status] = (c[t.status]||0) + 1);
  document.getElementById('s-crit').textContent = c.critical || 0;
  document.getElementById('s-prog').textContent = c.inprogress || 0;
  document.getElementById('s-mon').textContent = c.monitoring || 0;
  document.getElementById('s-done').textContent = c.done || 0;
}

function updateCatFilter() {
  const sel = document.getElementById('f-cat');
  const cur = sel.value;
  const cats = [...new Set(tasks.map(t => t.category))].sort();
  sel.innerHTML = '<option value="">All categories</option>' + cats.map(c => `<option${cur===c?' selected':''}>${c}</option>`).join('');
}

function filtered() {
  const fs = document.getElementById('f-status').value;
  const fsi = document.getElementById('f-site').value;
  const fcat = document.getElementById('f-cat').value;
  const fq = document.getElementById('f-search').value.toLowerCase();
  return tasks.filter(t => {
    if (fs && t.status !== fs) return false;
    if (fsi && t.site !== fsi) return false;
    if (fcat && t.category !== fcat) return false;
    if (fq && !(t.title.toLowerCase().includes(fq) || (t.notes||'').toLowerCase().includes(fq) || t.category.toLowerCase().includes(fq))) return false;
    return true;
  });
}

const CAT_ORDER = ['Website & Digital','Marketing & Enrollment','Legal / Incident','Staffing / Leadership','Staffing / Ratios','Enrollment / Move-ups','Operations / Tech','Legal / HR','HR / Benefits','Training & Curriculum'];
const collapsedCats = new Set(JSON.parse(localStorage.getItem('bb_collapsed_cats') || '[]'));

function toggleCat(cat) {
  const key = 'cat-body-' + btoa(unescape(encodeURIComponent(cat)));
  const hd = document.getElementById('cat-hd-' + key);
  const body = document.getElementById(key);
  if (!hd || !body) return;
  if (collapsedCats.has(cat)) {
    collapsedCats.delete(cat);
    hd.classList.remove('collapsed');
    body.classList.remove('hidden');
  } else {
    collapsedCats.add(cat);
    hd.classList.add('collapsed');
    body.classList.add('hidden');
  }
  localStorage.setItem('bb_collapsed_cats', JSON.stringify([...collapsedCats]));
}

function render() {
  updateStats();
  updateCatFilter();
  const list = document.getElementById('task-list');
  const ft = filtered();
  if (!ft.length) { list.innerHTML = '<div class="empty">No tasks match this filter.</div>'; return; }
  const groups = {};
  ft.forEach(t => { if (!groups[t.category]) groups[t.category] = []; groups[t.category].push(t); });
  const cats = CAT_ORDER.filter(c => groups[c]).concat(Object.keys(groups).filter(c => !CAT_ORDER.includes(c)));
  let html = '';
  cats.forEach(cat => {
    const key = 'cat-body-' + btoa(unescape(encodeURIComponent(cat)));
    const isCollapsed = collapsedCats.has(cat);
    const count = groups[cat].length;
    html += `<div class="section-wrap">
      <div class="section-hd${isCollapsed ? ' collapsed' : ''}" id="cat-hd-${key}" onclick="toggleCat(${JSON.stringify(cat)})">
        <div class="section-hd-left">
          <span>${cat}</span>
          <span class="section-count">${count}</span>
        </div>
        <svg class="section-chevron" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M5 8l5 5 5-5"/></svg>
      </div>
      <div class="section-body${isCollapsed ? ' hidden' : ''}" id="${key}">`;
    groups[cat].forEach(t => {
      html += `
      <div class="task-card${expandedIds[t.id] ? ' expanded' : ''}" id="tc-${t.id}">
        <div class="task-top" onclick="toggle(${t.id})">
          <div class="task-priority p-${t.status}"></div>
          <div class="task-main">
            <div class="task-title-row">
              ${t.priority ? priorityFlag(t.priority) : ''}
              <span class="task-name">${t.title}</span>
            </div>
            <div class="task-meta">${statusBadge(t.status)} ${siteBadge(t.site)}</div>
          </div>
          <svg class="chevron" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 8l5 5 5-5"/></svg>
        </div>
        <div class="task-detail">
          <div class="detail-grid">
            <div class="det-row">
              <span class="det-label">Notes</span>
              <div style="flex:1">
                <textarea class="note-area" id="note-${t.id}" onclick="event.stopPropagation()">${t.notes||''}</textarea>
                <div class="note-actions">
                  <button class="save-note" onclick="event.stopPropagation();saveNote(${t.id})">Save note</button>
                </div>
              </div>
            </div>
            ${t.deps ? `<div class="det-row"><span class="det-label">Dependencies</span><span class="det-val dep-text">${t.deps}</span></div>` : ''}
            <div class="det-row">
              <span class="det-label">Status</span>
              <div class="status-btns">
                <button class="sb${t.status==='critical'?' active-critical':''}" onclick="event.stopPropagation();setStatus(${t.id},'critical')">Critical</button>
                <button class="sb${t.status==='inprogress'?' active-inprogress':''}" onclick="event.stopPropagation();setStatus(${t.id},'inprogress')">In progress</button>
                <button class="sb${t.status==='monitoring'?' active-monitoring':''}" onclick="event.stopPropagation();setStatus(${t.id},'monitoring')">Monitoring</button>
                <button class="sb${t.status==='done'?' active-done':''}" onclick="event.stopPropagation();setStatus(${t.id},'done')">Done</button>
              </div>
            </div>
            <div class="det-row">
              <span class="det-label"></span>
              <button class="del-btn" onclick="event.stopPropagation();deleteTask(${t.id})">Delete task</button>
            </div>
          </div>
        </div>
      </div>`;
    });
    html += `</div></div>`;
  });
  list.innerHTML = html;
}

function toggle(id) {
  expandedIds[id] = !expandedIds[id];
  const el = document.getElementById('tc-' + id);
  if (el) el.classList.toggle('expanded', expandedIds[id]);
}

function saveNote(id) {
  const t = tasks.find(x => x.id === id); if (!t) return;
  t.notes = document.getElementById('note-' + id).value;
  saveTasks();
  showToast('Note saved');
}

function setStatus(id, status) {
  const t = tasks.find(x => x.id === id); if (!t) return;
  t.status = status;
  saveTasks();
  const was = expandedIds[id];
  render();
  if (was) { expandedIds[id] = true; const el = document.getElementById('tc-' + id); if (el) el.classList.add('expanded'); }
}

function deleteTask(id) {
  if (!confirm('Delete this task?')) return;
  tasks = tasks.filter(x => x.id !== id);
  delete expandedIds[id];
  saveTasks();
  render();
  showToast('Task deleted');
}

function openModal() { document.getElementById('modal').classList.add('open'); document.getElementById('m-title').focus(); }
function closeModal() { document.getElementById('modal').classList.remove('open'); }

function addTask() {
  const title = document.getElementById('m-title').value.trim();
  if (!title) { alert('Please enter a task title.'); return; }
  tasks.unshift({
    id: nextId++,
    title,
    status: document.getElementById('m-status').value,
    site: document.getElementById('m-site').value,
    category: document.getElementById('m-cat').value,
    priority: document.getElementById('m-priority').value,
    notes: document.getElementById('m-notes').value,
    deps: document.getElementById('m-deps').value
  });
  saveTasks();
  closeModal();
  document.getElementById('m-title').value = '';
  document.getElementById('m-notes').value = '';
  document.getElementById('m-deps').value = '';
  render();
  showToast('Task added');
}

function exportData() {
  const blob = new Blob([JSON.stringify(tasks, null, 2)], { type: 'application/json' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'bb_ops_tasks_' + new Date().toISOString().slice(0,10) + '.json';
  a.click();
}

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2000);
}

// Close modal on overlay click
document.getElementById('modal').addEventListener('click', e => { if (e.target === document.getElementById('modal')) closeModal(); });

// Enter key in title field
document.getElementById('m-title').addEventListener('keydown', e => { if (e.key === 'Enter') addTask(); });

render();
</script>
